{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalTeam",
  "version": "0.1.0",
  "identifier": "com.localteam.app",
  "build": {
    "beforeDevCommand": "cd src-sidecar && npm install && cd .. && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalTeam",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 820,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/localteam-sidecar"
    ],
    "resources": [
      "../templates/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
